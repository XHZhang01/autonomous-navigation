<launch>

  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen" clear_params="true">
    
    <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS" />
    <param name="base_global_planner" value="global_planner/GlobalPlanner" />

    
    <param name="navfn/allow_unknown" value="true"/>

    <rosparam file="$(find navigation)/config/mbot_kinect/costmap_common_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find navigation)/config/mbot_kinect/costmap_common_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find navigation)/config/mbot_kinect/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find navigation)/config/mbot_kinect/global_costmap_params.yaml" command="load" />

    <rosparam file="$(find navigation)/config/mbot_kinect/move_base_params.yaml" command="load" />
    <rosparam file="$(find navigation)/config/mbot_kinect/dwa_local_planner_params.yaml" command="load" />

    <remap from="/map" to="/projected_map" />
    <remap from="/odom" to="/current_state_est_foot" />
  </node>
  
</launch>
